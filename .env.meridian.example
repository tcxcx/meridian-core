# MERIDIAN-specific env (merge with upstream .env.example)
# Source-of-truth: .context/meridian/sponsor-docs/

# ===== 0G (Phase 3) =====
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
ZG_PRIVATE_KEY=
# Optional: route LLM_BASE_URL at 0G Compute if it exposes OpenAI-compat HTTP
# LLM_BASE_URL=<0g-compute-endpoint>

# ===== AXL (Phase 2) =====
AXL_NODE_URL=http://127.0.0.1:9002
AXL_MCP_ROUTER_URL=http://127.0.0.1:9003
AXL_PEER_IDS=             # comma-separated 64-hex public keys of peer nodes

# ===== KeeperHub (Phase 4) =====
KH_API_KEY=               # kh_... organization key
KH_DIRECT_API_KEY=        # keeper_... direct-execution key
KH_MCP_URL=https://app.keeperhub.com/mcp

# ===== Polymarket (Phase 1, 4) =====
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=   # treasury / read-only
POLYMARKET_PROXY_FUNDER=

# ===== Uniswap v4 + Fhenix CoFHE (Phase 4) =====
# CoFHE coprocessor lives on Base/Arbitrum/Ethereum Sepolia. Default: Base Sepolia.
FHENIX_RPC_URL=https://sepolia.base.org
FHENIX_PRIVATE_KEY=
V4_POOL_MANAGER=          # set after pool deploy

# ===== Uniswap Trading API (execution-router) =====
# Reference: .context/meridian/internal-references/uniswap-trading-api-from-desk-v1.md
UNISWAP_TRADING_API_KEY=
UNISWAP_TRADING_API_URL=https://trade-api.gateway.uniswap.org/v1
BURNER_PRIVATE_KEY=       # signer for execution-router swaps

# ===== Backend mode flags =====
LLM_PROVIDER=openai       # openai | 0g
MEMORY_BACKEND=zep        # zep | 0g (per-call feature flag for staged migration)
