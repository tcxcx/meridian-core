# ──────────────────────────────────────────────────────────────────────────────
# MERIDIAN demo readiness checklist
# Layered envelopes — each tier unlocks one more real backend.
# Run `make e2e-real` to validate which tier you've reached.
# ──────────────────────────────────────────────────────────────────────────────
#
# Tier 0 · DRY-RUN ONLY        no keys needed
#   What works:  dashboard at :5004/, ?demo=1 seed, SQLite audit, SSE stream,
#                tenant routing, burner derivation, all graceful fallbacks.
#   What fakes:  swarm verdicts (lite synthetic), 0G hashes (null),
#                bridge txs (tr_dryrun_*), CLOB order ids (DRY_RUN_*),
#                fundBurner/settle (skipped), FHE encrypt (zeroed).
#
# Tier 1 · REAL SWARM          add LLM_API_KEY
#   Unlocks:     gpt-4o-mini (or 0G Compute) deliberation in DELIBERATE.
#   Verifier:    POST /api/signal/run → response.swarm_prediction non-zero
#                AND response.contributing_agents > 0.
#
# Tier 2 · REAL CLOB           add POLYMARKET_PRIVATE_KEY + BURNER_SEED
#   Unlocks:     burner EOAs sign live Polymarket orders on Polygon Amoy.
#   Verifier:    /api/execution/open → clob_order_id NOT prefixed DRY_RUN_.
#   Caution:     Polymarket Amoy needs at least one mock-USDC funded burner.
#
# Tier 3 · REAL SETTLEMENT     add TREASURY_PRIVATE_KEY + ARB_SEPOLIA_RPC_URL
#                                 + MERIDIAN_HOOK_ADDRESS (deploy hook first)
#   Unlocks:     fundBurner / markResolved / settle on Arb Sepolia.
#   Verifier:    /api/execution/open → fund_tx is a real 0x… on Arb Sepolia.
#   Deploy:      cd contracts && forge script script/DeployPrivateSettlement.s.sol \
#                  --rpc-url $ARB_SEPOLIA_RPC_URL --broadcast --via-ir
#
# Tier 4 · REAL BRIDGE         treasury pre-deposits unified balance into
#                              Arbitrum Sepolia GatewayWallet (one-time setup).
#   Unlocks:     /bridge and /bridge/deposit return real Circle CCTP burn+mint
#                tx hashes; cogito /health.gateway shows balance > 0.
#   Verifier:    /api/execution/open → bridge_send_burn_tx + bridge_send_mint_tx
#                are real txs, not tr_dryrun_*.
#   Setup:       see services/cogito/README.md → "Gateway treasury bootstrap".
#
# Tier 5 · REAL 0G ANCHOR      add ZG_PRIVATE_KEY (funded ≥ 3 OG)
#   Unlocks:     POST /api/signal/run → seed_hash_0g + simulation_hash_0g
#                are non-null root hashes pinned to 0G Storage Galileo.
#   BLOCKED:     0G Galileo faucet (https://faucet.0g.ai) currently down.
#                Re-attempt when the faucet returns.
#
# Tier 6 · REAL FHE            add FHE_PRIVATE_KEY (or reuse TREASURY_PRIVATE_KEY)
#   Unlocks:     POST /fhe/encrypt → real InEuint128 sealed inputs that
#                PrivateSettlementHook.unlockCallback() will accept.
#   Verifier:    /api/execution/open → fund_tx contains InEuint128 calldata
#                (not the zeroed-payload fallback).
#
# ──────────────────────────────────────────────────────────────────────────────
# COPY-PASTE TEMPLATE — fill what you have, leave the rest blank.
# Run `make e2e-real` to see your readiness tier.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Tier 1 · Real swarm ──────────────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
LLM_PROVIDER=openai
SWARM_BACKEND=lite                  # flip to "axl" once AXL mesh is up

# ─── Tier 2 · Real Polymarket CLOB ────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=80002           # Polygon Amoy testnet
BURNER_SEED=                        # 32-byte hex; per-position EOA = keccak(SEED‖position_id)

# ─── Tier 3 · Real settlement on Arbitrum Sepolia ─────────────────────────────
TREASURY_PRIVATE_KEY=
ARB_SEPOLIA_RPC_URL=https://arbitrum-sepolia.publicnode.com
MERIDIAN_HOOK_ADDRESS=              # set after `forge script DeployPrivateSettlement`

# ─── Tier 4 · Real Circle Gateway bridge ──────────────────────────────────────
# (No new keys — uses TREASURY_PRIVATE_KEY. Treasury must pre-deposit USDC into
#  the Arbitrum Sepolia GatewayWallet contract once. See cogito README.)
BRIDGE_SETTLEMENT_CHAIN=Arbitrum_Sepolia
BRIDGE_TRADING_CHAIN=Polygon_Amoy_Testnet

# ─── Tier 5 · Real 0G Storage + Compute (BLOCKED ON FAUCET) ───────────────────
ZG_PRIVATE_KEY=
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# ─── Tier 6 · Real cofhejs / Fhenix CoFHE ─────────────────────────────────────
FHE_PRIVATE_KEY=                    # leave blank → falls back to TREASURY_PRIVATE_KEY
FHE_RPC_URL=                        # leave blank → falls back to ARB_SEPOLIA_RPC_URL

# ─── Always-on (every tier) ───────────────────────────────────────────────────
COGITO_TOKEN=                       # any long random string (>= 32 chars)
COGITO_URL=http://127.0.0.1:5003
COGITO_PORT=5003
COGITO_HOST=127.0.0.1

EXECUTION_ROUTER_PORT=5004
SIGNAL_GATEWAY_PORT=5002
SIGNAL_GATEWAY_URL=http://127.0.0.1:5002
EXECUTION_ROUTER_URL=http://127.0.0.1:5004

# Optional: KeeperHub direct-execution wrapper (otherwise treasury submits direct)
KEEPERHUB_API_KEY=
KEEPERHUB_NETWORK=421614

# Optional: tenant list (omit for single-tenant default)
TENANTS=                            # csv, e.g. "fund-a,fund-b"

# Orchestrator (autonomous loop) — keep modest for testnet
ORCHESTRATOR_USDC_PER_POSITION=1.0
ORCHESTRATOR_MAX_POSITIONS=1
ORCHESTRATOR_MIN_EDGE_PP=3.0
ORCHESTRATOR_MIN_CONFIDENCE=0.55
ORCHESTRATOR_DRY_RUN=false
