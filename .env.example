# MERIDIAN env — copy to `.env` and fill the required fields.
# All sidecars degrade gracefully when optional vars are missing — see README.md.

# ─── LLM (signal-gateway swarm) ───────────────────────────────────────────────
LLM_API_KEY=sk-...                                   # required (ignored when LLM_PROVIDER=0g)
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
LLM_PROVIDER=openai                                  # openai | 0g (route through cogito /compute/inference)
COGITO_LLM_MODEL=openai/gpt-oss-20b                  # 0G DeAIOS model when LLM_PROVIDER=0g

# Upstream MiroFish memory graph (optional — only if you wire the upstream backend)
ZEP_API_KEY=

# ─── cogito sidecar (TS/Bun on :5003) ─────────────────────────────────────────
# 0G Storage + 0G Compute (signer pays testnet OG for upload gas + ledger)
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
ZG_PRIVATE_KEY=0x...                                 # required: funded 0G Galileo testnet wallet

# Localhost auth shared with all Python callers
COGITO_TOKEN=replace-with-a-long-random-string       # required

COGITO_PORT=5003
COGITO_HOST=127.0.0.1                                # do NOT bind 0.0.0.0
COGITO_MAX_BODY_BYTES=1048576
COGITO_RATE_LIMIT_PER_MIN=60

# ─── signal-gateway (Flask :5002) ─────────────────────────────────────────────
SIGNAL_GATEWAY_PORT=5002
SWARM_BACKEND=lite                                   # lite | axl (3-node Gensyn AXL mesh)
SWARM_AGENTS_PER_NODE=5                              # SWARM_BACKEND=axl only
SWARM_ROUNDS=2                                       # SWARM_BACKEND=axl only

# Python callers point at cogito over loopback
COGITO_URL=http://127.0.0.1:5003                     # bridge_client + zg_client + encryptor

# ─── execution-router (Flask :5004) ───────────────────────────────────────────
EXECUTION_ROUTER_PORT=5004

# Burner EOA derivation. Must be 32 bytes hex. Any per-position EOA is
#   keccak(BURNER_SEED ‖ position_id) — keep this OUT of git, even on testnet.
BURNER_SEED=0x...                                    # required

# Settlement chain (Arbitrum Sepolia, Fhenix CoFHE)
# Public RPCs throttle aggressively under demo load. For pre-demo gates use a
# paid endpoint (Alchemy / QuickNode / Ankr Premium / Infura). Example:
#   ARB_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/<key>
ARB_SEPOLIA_RPC_URL=https://arbitrum-sepolia.publicnode.com
MERIDIAN_HOOK_ADDRESS=0x...                          # deployed PrivateSettlementHook (CREATE2-mined)
TREASURY_PRIVATE_KEY=0x...                           # signs fundBurner / markResolved / settle / Bridge Kit burns

# KeeperHub Direct Execution (optional — falls back to direct treasury submission)
KEEPERHUB_API_KEY=
KEEPERHUB_NETWORK=421614                             # Arbitrum Sepolia

# Bridge Kit chains (Circle CCTP V2 — Arb Sepolia ↔ Polygon Amoy)
BRIDGE_SETTLEMENT_CHAIN=Arbitrum_Sepolia             # /open source, /resolve destination
BRIDGE_TRADING_CHAIN=Polygon_Amoy_Testnet            # /open destination, /resolve source

# ── Pinata agent reach-back (optional) ────────────────────────────────────────
# When the Pinata-hosted MoonPay Prediction Market Trader agent calls MiroShark
# from outside localhost (via ngrok / cloudflared / public deploy), set this
# token to require Authorization: Bearer <token> on every /api/* call to both
# execution-router (:5004) and signal-gateway (:5002). Cogito (:5003) already
# has its own bearer token (COGITO_TOKEN). /health stays open on all services
# so the operator dashboard + tunnel inspector can probe liveness.
# Generate: openssl rand -hex 32
MIROSHARK_AGENT_TOKEN=

# Trading chain (Polygon Amoy, Polymarket CLOB).
# clob_client + bridge polling both read this — pin a paid endpoint for demo:
#   POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/<key>
# Public default (rate-limited):
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Fhenix CoFHE (cogito /fhe/encrypt)
FHE_PRIVATE_KEY=                                     # falls back to TREASURY_PRIVATE_KEY when blank
FHE_RPC_URL=                                         # falls back to ARB_SEPOLIA_RPC_URL → ZG_RPC_URL when blank

# Polymarket CLOB (per-burner trading on Polygon Amoy)
POLYMARKET_API_KEY=                                  # optional — when blank, clob_client returns dry-run order ids
POLYMARKET_HOST=https://clob.polymarket.com

# ─── orchestrator (autonomous loop) ───────────────────────────────────────────
SIGNAL_GATEWAY_URL=http://127.0.0.1:5002
EXECUTION_ROUTER_URL=http://127.0.0.1:5004
ORCHESTRATOR_INTERVAL_S=60
ORCHESTRATOR_MAX_POSITIONS=1
ORCHESTRATOR_MIN_EDGE_PP=3.0
ORCHESTRATOR_MIN_CONFIDENCE=0.55
ORCHESTRATOR_USDC_PER_POSITION=5.0
ORCHESTRATOR_DRY_RUN=false                           # true → log-only, never hits /open

# ─── ENS (sponsor track — agent identity layer) ────────────────────────────
# Read-side resolution works against any registered name on mainnet without
# any of these set. To mint MiroShark-owned subnames on Sepolia and surface
# them in the operator terminal, configure the lot below and run:
#   node apps/app/scripts/ens/check.mjs       # preflight (read-only)
#   node apps/app/scripts/ens/register.mjs    # mints subnames + sets text records

ENS_NETWORK=mainnet                                    # mainnet | sepolia (controls /api/ens/resolve target)
MAINNET_RPC_URL=                                       # paid RPC recommended for production resolution; blank → public default
SEPOLIA_RPC_URL=                                       # blank → https://ethereum-sepolia.publicnode.com
ENS_REGISTRAR_PRIVATE_KEY=                             # blank → falls back to TREASURY_PRIVATE_KEY for the register script
MIROSHARK_PARENT_ENS_NAME=miroshark.eth                # parent name the registrar signer must own on Sepolia
MIROSHARK_AGENT_ENS=                                   # explicit override; defaults to xt1sgi73.<parent>
MIROSHARK_TENANT_ENS_FUND_A=                           # explicit override; defaults to fund-a.<parent>
MIROSHARK_TENANT_ENS_FUND_B=                           # explicit override; defaults to fund-b.<parent>
MIROSHARK_TENANT_ADDRESS_FUND_A=                       # destination address for fund-a subname (defaults to TRADING_WALLET_ADDRESS)
MIROSHARK_TENANT_ADDRESS_FUND_B=                       # destination address for fund-b subname (defaults to TRADING_WALLET_ADDRESS)
TRADING_WALLET_ADDRESS=                                # destination for xt1sgi73 subname; defaults to signer

# ─── Circle Developer-Controlled Wallets (sponsor track + atomic provisioning) ─
# When set, /api/funds creates Circle-managed wallets per fund instead of
# deriving from BURNER_SEED. Each fund gets its own treasury + trading wallet
# under a per-owner wallet set; addresses go into the ENS subname; wallet IDs
# persist on miroshark_fund.{treasury_wallet_id, trading_wallet_id, wallet_set_id}.
#
# How to provision (one-time, see Circle skill):
#   1. Sign up at https://console.circle.com → developer-controlled wallets
#   2. Create an API key → CIRCLE_API_KEY
#   3. Register an entity secret per https://developers.circle.com/w3s/entity-secret-management
#      → ENTITY_SECRET (the registered secret hex, NOT the recovery file)
#   4. Optional: pick blockchain (default ETH-SEPOLIA, EVM EOA address is universal)
CIRCLE_API_KEY=
ENTITY_SECRET=
CIRCLE_DEFAULT_BLOCKCHAIN=ETH-SEPOLIA

# Circle bridge — internal auth token shared between the Next.js
# /api/circle/execute route and the Python execution_router. Generate with
# `openssl rand -hex 32`. When unset, the bridge is open in dev (warn in prod).
CIRCLE_BRIDGE_TOKEN=
MIROSHARK_APP_URL=http://127.0.0.1:3301
